# ── Node.js ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ── WhatsApp Web auth session (contains sensitive data & locked files) ──
whatsapp-service/.wwebjs_auth/
whatsapp-service/.wwebjs_cache/
whatsapp-service/.wwebjs_*

# ── Frontend build output ────────────────────────────────────────
dist/
build/
frontend/dist/
frontend/.vite/

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
.eggs/

# ── Flask / SQLite database ──────────────────────────────────────
backend/instance/
*.db
*.sqlite
*.sqlite3

# ── Environment files ────────────────────────────────────────────
.env
.env.local
.env.*
.env.*.local
# Keep .env.example so others know what vars to set
!.env.example

# ── OS files ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ───────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
